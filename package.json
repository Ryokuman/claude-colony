{
  "name": "agent-hive",
  "version": "0.2.0",
  "description": "AI agent teams that autonomously handle GitHub issues — worker codes, reviewer reviews, they ping-pong until approved.",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "agent-hive": "dist/cli.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/prompts/**/*.md"
  ],
  "scripts": {
    "build": "tsc && rm -rf dist/prompts && cp -r src/prompts dist/prompts",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "claude",
    "ai",
    "autonomous",
    "development",
    "agent",
    "code-review",
    "github",
    "pull-request",
    "agent-teams"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ryokuman/claude-colony.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "vitest": "^4.1.0"
  }
}
